generator client {
    provider     = "prisma-client"
    output       = "../generated/prisma"
    moduleFormat = "cjs"
}

datasource db {
    provider = "postgresql"
}

model Profile {
    id String @id @default(uuid())

    /// The Clerk user ID this profile belongs to.
    clerkId String @unique

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}
